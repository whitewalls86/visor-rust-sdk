#!/usr/bin/env bash
# check-contracts — Show current contract test compilation status.
#
# The Phase 2 contract tests are intentional compile-time failures until
# Phase 4 (models) and Phase 5 (client methods) land. This script makes
# that state explicit and visible rather than silently excluded from the
# pre-commit hook.
#
# Usage:
#   bash scripts/check-contracts
#
# Expected output until Phase 4+: unresolved import and missing method errors.
# Expected output after Phase 5: all tests pass.

set -euo pipefail

echo "=== Contract test status (failures expected until Phase 4/5) ==="
echo ""
cargo test 2>&1 || true
echo ""
echo "=== Current passing gate ==="
echo "  cargo fmt --check"
echo "  cargo clippy --lib --all-features -- -D warnings"
echo "  cargo check --lib"
echo ""
echo "Restore --all-targets and cargo test in .githooks/pre-commit once Phase 4+ is complete."
